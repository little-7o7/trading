//@version=5
indicator("ScalpMaster Pro v4", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════════════════════════
//  INPUTS
// ══════════════════════════════════════════════════════════════════════════════

grp_main = "═══ MAIN ═══"
pipSize      = input.float(0.1, "Pip Size (Gold=0.1, Forex=0.0001)", group=grp_main)
slPips       = input.float(20.0, "Stop Loss (Pips)", group=grp_main)
useFixedTP   = input.bool(false, "Use Fixed TP (otherwise Smart TP)", group=grp_main)
fixedRR      = input.float(3.0, "Fixed R:R (if enabled)", minval=1.0, step=0.5, group=grp_main)
cooldownBars = input.int(10, "Cooldown Bars", minval=1, group=grp_main)
atrLen       = input.int(14, "ATR Length", group=grp_main)

grp_ict = "═══ ICT / SMC ═══"
showOB       = input.bool(true, "Order Blocks", group=grp_ict)
showFVG      = input.bool(true, "Fair Value Gaps", group=grp_ict)
showBOS      = input.bool(true, "BOS / CHoCH", group=grp_ict)
showSweep    = input.bool(true, "Liquidity Sweeps", group=grp_ict)
showOTE      = input.bool(true, "OTE Zone (0.62-0.79 Fib)", group=grp_ict)
showDisplace = input.bool(true, "Displacement Candles", group=grp_ict)
showInduce   = input.bool(true, "Inducement Levels", group=grp_ict)
swingLB      = input.int(5, "Swing Lookback", minval=2, maxval=20, group=grp_ict)

grp_snr = "═══ SNR ═══"
showSNR      = input.bool(true, "Show S/R Levels", group=grp_snr)
snrStrength  = input.int(10, "S/R Pivot Strength", minval=3, maxval=30, group=grp_snr)
showDailyHL  = input.bool(true, "Daily High/Low", group=grp_snr)
showWeeklyHL = input.bool(true, "Weekly High/Low", group=grp_snr)
showPrevClose= input.bool(true, "Previous Day Close", group=grp_snr)

grp_kill = "═══ ICT Killzones ═══"
showKZ       = input.bool(true, "Show Killzones", group=grp_kill)
kzLondonS    = input.int(7, "London Start (UTC)", group=grp_kill)
kzLondonE    = input.int(10, "London End (UTC)", group=grp_kill)
kzNYS        = input.int(12, "NY Start (UTC)", group=grp_kill)
kzNYE        = input.int(15, "NY End (UTC)", group=grp_kill)

grp_news = "═══ NEWS ═══"
showNews     = input.bool(true, "Show News Zones", group=grp_news)
newsBuffer   = input.int(30, "Avoid X min Before News", minval=5, maxval=120, group=grp_news)
nfpOn        = input.bool(true, "NFP (1st Fri 13:30 UTC)", group=grp_news)
fomcOn       = input.bool(true, "FOMC (18:00 UTC)", group=grp_news)

grp_ema = "═══ EMA ═══"
emaF = input.int(9, "Fast", group=grp_ema)
emaM = input.int(21, "Mid", group=grp_ema)
emaS = input.int(50, "Slow", group=grp_ema)
showEma = input.bool(true, "Show", group=grp_ema)

grp_rsi = "═══ RSI ═══"
rsiLen = input.int(14, "Length", group=grp_rsi)

grp_macd = "═══ MACD ═══"
mcdF = input.int(12, "Fast", group=grp_macd)
mcdS = input.int(26, "Slow", group=grp_macd)
mcdSig = input.int(9, "Signal", group=grp_macd)

grp_adx = "═══ ADX ═══"
adxLen = input.int(14, "Length", group=grp_adx)
adxTh  = input.int(20, "Threshold", group=grp_adx)

grp_vol = "═══ Volume ═══"
volLen = input.int(20, "MA Length", group=grp_vol)
volTh  = input.float(1.3, "Spike Thresh", group=grp_vol)

grp_bb = "═══ Bollinger ═══"
bbLen  = input.int(20, "Length", group=grp_bb)
bbMult = input.float(2.0, "StdDev", group=grp_bb)
showBB = input.bool(false, "Show", group=grp_bb)

grp_mtf = "═══ Multi-Timeframe ═══"
htfOn = input.bool(true, "Enable HTF", group=grp_mtf)
htf   = input.timeframe("5", "Higher TF", group=grp_mtf)

grp_vwap = "═══ VWAP ═══"
showVwap   = input.bool(true, "Show", group=grp_vwap)
vwapFilter = input.bool(true, "Direction Filter", group=grp_vwap)

grp_disp = "═══ Display ═══"
showTable   = input.bool(true, "Signal Table", group=grp_disp)
showSLTP    = input.bool(true, "SL/TP Lines", group=grp_disp)
showSignals = input.bool(true, "Signal Labels", group=grp_disp)
tablePos    = input.string("Top Right", "Table Position", options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grp_disp)

// ══════════════════════════════════════════════════════════════════════════════
//  CORE DATA — [1] = NO REPAINT
// ══════════════════════════════════════════════════════════════════════════════

float c1 = close[1]
float c2 = close[2]
float c3 = close[3]
float o1 = open[1]
float o2 = open[2]
float o3 = open[3]
float h1 = high[1]
float h2 = high[2]
float h3 = high[3]
float l1 = low[1]
float l2 = low[2]
float l3 = low[3]
float v1 = volume[1]

float atrVal = ta.atr(atrLen)[1]
float slDist = slPips * pipSize

// ══════════════════════════════════════════════════════════════════════════════
//  CLASSIC INDICATORS
// ══════════════════════════════════════════════════════════════════════════════

float emaFast = ta.ema(close, emaF)[1]
float emaMid  = ta.ema(close, emaM)[1]
float emaSlow = ta.ema(close, emaS)[1]

float rsiVal  = ta.rsi(close, rsiLen)[1]
float rsiPrev = ta.rsi(close, rsiLen)[2]

[macdL, sigL, histL] = ta.macd(close, mcdF, mcdS, mcdSig)
float macdVal  = macdL[1]
float sigVal   = sigL[1]
float histVal  = histL[1]
float histPrev = histL[2]

float stKRaw_v = ta.sma(ta.stoch(close, high, low, 14), 3)
float stKVal = stKRaw_v[1]
float stKP   = stKRaw_v[2]
float stDRaw_v = ta.sma(stKRaw_v, 3)
float stDVal = stDRaw_v[1]
float stDP   = stDRaw_v[2]

float volMA = ta.sma(volume, volLen)[1]
bool volSpike = v1 > volMA * volTh

float bbBasis = ta.sma(close, bbLen)[1]
float bbDev   = ta.stdev(close, bbLen)[1] * bbMult
float bbUp = bbBasis + bbDev
float bbLo = bbBasis - bbDev

[diP, diM, adxV] = ta.dmi(adxLen, adxLen)
float adxC = adxV[1]
float diPC = diP[1]
float diMC = diM[1]

float vwapVal = ta.vwap(hlc3)[1]

float swHi = ta.highest(high, swingLB)[1]
float swLo = ta.lowest(low, swingLB)[1]

// ══════════════════════════════════════════════════════════════════════════════
//  SNR
// ══════════════════════════════════════════════════════════════════════════════

float pvtHi = ta.pivothigh(high, snrStrength, snrStrength)
float pvtLo = ta.pivotlow(low, snrStrength, snrStrength)

var float res1 = na
var float sup1 = na

if not na(pvtHi)
    res1 := pvtHi
if not na(pvtLo)
    sup1 := pvtLo

float dHigh  = request.security(syminfo.tickerid, "D", high[1], barmerge.gaps_off, barmerge.lookahead_on)
float dLow   = request.security(syminfo.tickerid, "D", low[1], barmerge.gaps_off, barmerge.lookahead_on)
float dClose = request.security(syminfo.tickerid, "D", close[1], barmerge.gaps_off, barmerge.lookahead_on)
float wHigh  = request.security(syminfo.tickerid, "W", high[1], barmerge.gaps_off, barmerge.lookahead_on)
float wLow   = request.security(syminfo.tickerid, "W", low[1], barmerge.gaps_off, barmerge.lookahead_on)

plot(showSNR and not na(res1) ? res1 : na, "Resistance", color.new(#ff1744, 30), 2, plot.style_linebr)
plot(showSNR and not na(sup1) ? sup1 : na, "Support", color.new(#00e676, 30), 2, plot.style_linebr)
plot(showDailyHL ? dHigh : na, "Daily High", color.new(#ff9800, 40), 1, plot.style_stepline)
plot(showDailyHL ? dLow : na, "Daily Low", color.new(#ff9800, 40), 1, plot.style_stepline)
plot(showPrevClose ? dClose : na, "Prev Close", color.new(#9e9e9e, 50), 1, plot.style_cross)
plot(showWeeklyHL ? wHigh : na, "Weekly High", color.new(#e040fb, 50), 1, plot.style_stepline)
plot(showWeeklyHL ? wLow : na, "Weekly Low", color.new(#e040fb, 50), 1, plot.style_stepline)

float nearestRes = not na(res1) and res1 > c1 ? res1 : (not na(dHigh) and dHigh > c1 ? dHigh : c1 + atrVal * 4)
float nearestSup = not na(sup1) and sup1 < c1 ? sup1 : (not na(dLow) and dLow < c1 ? dLow : c1 - atrVal * 4)

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: BOS / CHoCH
// ══════════════════════════════════════════════════════════════════════════════

float pvH = ta.pivothigh(high, swingLB, swingLB)
float pvL = ta.pivotlow(low, swingLB, swingLB)

var float lastPH = na
var float prevPH = na
var float lastPL = na
var float prevPL = na

if not na(pvH)
    prevPH := lastPH
    lastPH := pvH
if not na(pvL)
    prevPL := lastPL
    lastPL := pvL

bool bullBOS = not na(lastPH) and c1 > lastPH and c2 <= lastPH
bool bearBOS = not na(lastPL) and c1 < lastPL and c2 >= lastPL
bool bullCHoCH = bullBOS and not na(prevPL) and not na(lastPL) and lastPL < prevPL
bool bearCHoCH = bearBOS and not na(prevPH) and not na(lastPH) and lastPH > prevPH

if showBOS and bullBOS
    label.new(bar_index, h1, bullCHoCH ? "CHoCH ▲" : "BOS ▲", style=label.style_label_down, color=color.new(#00e676, 30), textcolor=#00e676, size=size.tiny)
if showBOS and bearBOS
    label.new(bar_index, l1, bearCHoCH ? "CHoCH ▼" : "BOS ▼", style=label.style_label_up, color=color.new(#ff1744, 30), textcolor=#ff1744, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: ORDER BLOCKS
// ══════════════════════════════════════════════════════════════════════════════

float body1 = math.abs(c1 - o1)

bool bullOB = c3 < o3 and c2 > o2 and c1 > o1 and c1 > h3 and body1 > atrVal * 0.5
bool bearOB = c3 > o3 and c2 < o2 and c1 < o1 and c1 < l3 and body1 > atrVal * 0.5

var float bOB_t = na
var float bOB_b = na
var float sOB_t = na
var float sOB_b = na

if bullOB
    bOB_t := math.max(o3, c3)
    bOB_b := math.min(o3, c3)
if bearOB
    sOB_t := math.max(o3, c3)
    sOB_b := math.min(o3, c3)

bool inBullOB = not na(bOB_b) and c1 >= bOB_b and c1 <= bOB_t
bool inBearOB = not na(sOB_t) and c1 >= sOB_b and c1 <= sOB_t

if showOB and bullOB
    box.new(bar_index - 3, bOB_t, bar_index + 15, bOB_b, bgcolor=color.new(#00e676, 88), border_color=color.new(#00e676, 50))
    label.new(bar_index - 3, bOB_b, "OB", style=label.style_label_up, color=color.new(#00e676, 60), textcolor=#00e676, size=size.tiny)
if showOB and bearOB
    box.new(bar_index - 3, sOB_t, bar_index + 15, sOB_b, bgcolor=color.new(#ff1744, 88), border_color=color.new(#ff1744, 50))
    label.new(bar_index - 3, sOB_t, "OB", style=label.style_label_down, color=color.new(#ff1744, 60), textcolor=#ff1744, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: FVG
// ══════════════════════════════════════════════════════════════════════════════

bool bullFVG = l1 > h3 and c2 > o2
bool bearFVG = h1 < l3 and c2 < o2

var float bFVG_t = na
var float bFVG_b = na
var float sFVG_t = na
var float sFVG_b = na

if bullFVG
    bFVG_t := l1
    bFVG_b := h3
if bearFVG
    sFVG_t := l3
    sFVG_b := h1

bool inBullFVG = not na(bFVG_b) and c1 <= bFVG_t and c1 >= bFVG_b
bool inBearFVG = not na(sFVG_t) and c1 >= sFVG_b and c1 <= sFVG_t

if showFVG and bullFVG
    box.new(bar_index - 1, l1, bar_index + 12, h3, bgcolor=color.new(#2196f3, 85), border_color=color.new(#2196f3, 50))
if showFVG and bearFVG
    box.new(bar_index - 1, l3, bar_index + 12, h1, bgcolor=color.new(#ff9800, 85), border_color=color.new(#ff9800, 50))

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: DISPLACEMENT
// ══════════════════════════════════════════════════════════════════════════════

float avgBody = ta.sma(math.abs(close - open), 20)[1]
bool bullDisplace = c1 > o1 and body1 > avgBody * 2.5 and v1 > volMA
bool bearDisplace = c1 < o1 and body1 > avgBody * 2.5 and v1 > volMA

if showDisplace and bullDisplace
    label.new(bar_index, l1, "DISP", style=label.style_label_up, color=color.new(#00bcd4, 40), textcolor=#00bcd4, size=size.tiny)
if showDisplace and bearDisplace
    label.new(bar_index, h1, "DISP", style=label.style_label_down, color=color.new(#ff9800, 40), textcolor=#ff9800, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: LIQUIDITY SWEEP
// ══════════════════════════════════════════════════════════════════════════════

bool bullSweep = l1 < swLo and c1 > swLo and c1 > o1
bool bearSweep = h1 > swHi and c1 < swHi and c1 < o1

if showSweep and bullSweep
    label.new(bar_index, l1, "LIQ ▲", style=label.style_label_up, color=color.new(#00bcd4, 20), textcolor=#00bcd4, size=size.tiny)
if showSweep and bearSweep
    label.new(bar_index, h1, "LIQ ▼", style=label.style_label_down, color=color.new(#ff9800, 20), textcolor=#ff9800, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: OTE ZONE
// ══════════════════════════════════════════════════════════════════════════════

float swRange = swHi - swLo
float ote_bull_top = swLo + swRange * 0.382
float ote_bull_bot = swLo + swRange * 0.21
float ote_bear_top = swHi - swRange * 0.21
float ote_bear_bot = swHi - swRange * 0.382

bool inBullOTE = c1 >= ote_bull_bot and c1 <= ote_bull_top
bool inBearOTE = c1 >= ote_bear_bot and c1 <= ote_bear_top

plot(showOTE ? ote_bull_top : na, "OTE Top", color.new(#00e676, 70), 1, plot.style_linebr)
plot(showOTE ? ote_bull_bot : na, "OTE Bot", color.new(#00e676, 70), 1, plot.style_linebr)

// ══════════════════════════════════════════════════════════════════════════════
//  ICT: INDUCEMENT
// ══════════════════════════════════════════════════════════════════════════════

float minorPvtH = ta.pivothigh(high, 3, 3)
float minorPvtL = ta.pivotlow(low, 3, 3)

var float indH = na
var float indL = na
if not na(minorPvtH)
    indH := minorPvtH
if not na(minorPvtL)
    indL := minorPvtL

bool bullInduce = not na(indL) and l1 < indL and c1 > indL and not na(lastPL) and c1 > lastPL
bool bearInduce = not na(indH) and h1 > indH and c1 < indH and not na(lastPH) and c1 < lastPH

if showInduce and bullInduce
    label.new(bar_index, l1, "IDM", style=label.style_label_up, color=color.new(#e040fb, 40), textcolor=#e040fb, size=size.tiny)
if showInduce and bearInduce
    label.new(bar_index, h1, "IDM", style=label.style_label_down, color=color.new(#e040fb, 40), textcolor=#e040fb, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  KILLZONES + NEWS
// ══════════════════════════════════════════════════════════════════════════════

int utcH = hour(time, "UTC")
int utcMin = minute(time, "UTC")

bool inLondon = utcH >= kzLondonS and utcH < kzLondonE
bool inNY     = utcH >= kzNYS and utcH < kzNYE
bool inKillzone = inLondon or inNY

bgcolor(showKZ and inLondon ? color.new(#2196f3, 94) : showKZ and inNY ? color.new(#ff9800, 94) : na)

int dow = dayofweek(time, "UTC")
int dom = dayofmonth(time, "UTC")

bool isFirstFriday = dow == 6 and dom <= 7
bool nfpTime = nfpOn and isFirstFriday and utcH == 13 and utcMin >= 25 and utcMin <= 35
bool fomcTime = fomcOn and ((utcH == 17 and utcMin >= 55) or (utcH == 18 and utcMin <= 5))

bool isNearNFP  = nfpOn and isFirstFriday and utcH == 13 and utcMin < 30 and utcMin >= (30 - newsBuffer)
bool isNearFOMC = fomcOn and utcH == 17 and utcMin >= (60 - newsBuffer)
bool newsActive = nfpTime or fomcTime
bool newsDanger = isNearNFP or isNearFOMC or newsActive

if showNews and nfpTime
    label.new(bar_index, h1 + atrVal, "NFP!", style=label.style_label_down, color=color.new(#ff1744, 0), textcolor=color.white, size=size.normal)
if showNews and fomcTime
    label.new(bar_index, h1 + atrVal, "FOMC!", style=label.style_label_down, color=color.new(#ff9800, 0), textcolor=color.white, size=size.normal)
bgcolor(newsDanger and showNews ? color.new(#ff1744, 90) : na)

// ══════════════════════════════════════════════════════════════════════════════
//  PRICE ACTION + DIVERGENCE
// ══════════════════════════════════════════════════════════════════════════════

float upWick1 = h1 - math.max(c1, o1)
float dnWick1 = math.min(c1, o1) - l1

bool bullEngulf = c1 > o1 and c2 < o2 and c1 > o2 and o1 < c2
bool bearEngulf = c1 < o1 and c2 > o2 and c1 < o2 and o1 > c2
bool bullPin = dnWick1 > body1 * 2.0 and upWick1 < body1
bool bearPin = upWick1 > body1 * 2.0 and dnWick1 < body1
bool bullPA = bullEngulf or bullPin
bool bearPA = bearEngulf or bearPin

float rsiPvtL = ta.pivotlow(ta.rsi(close, rsiLen), 5, 5)
float rsiPvtH = ta.pivothigh(ta.rsi(close, rsiLen), 5, 5)
float prcPvtL = ta.pivotlow(low, 5, 5)
float prcPvtH = ta.pivothigh(high, 5, 5)

var float lRL = na
var float pRL = na
var float lRH = na
var float pRH = na
var float lPL = na
var float pPL = na
var float lPH = na
var float pPH = na

if not na(rsiPvtL) and not na(prcPvtL)
    pRL := lRL
    lRL := rsiPvtL
    pPL := lPL
    lPL := prcPvtL
if not na(rsiPvtH) and not na(prcPvtH)
    pRH := lRH
    lRH := rsiPvtH
    pPH := lPH
    lPH := prcPvtH

bool bullDiv = not na(pPL) and lPL < pPL and lRL > pRL
bool bearDiv = not na(pPH) and lPH > pPH and lRH < pRH

// ══════════════════════════════════════════════════════════════════════════════
//  HTF FILTER
// ══════════════════════════════════════════════════════════════════════════════

float htfEF = request.security(syminfo.tickerid, htf, ta.ema(close, emaF)[1], barmerge.gaps_off, barmerge.lookahead_on)
float htfEM = request.security(syminfo.tickerid, htf, ta.ema(close, emaM)[1], barmerge.gaps_off, barmerge.lookahead_on)
float htfES = request.security(syminfo.tickerid, htf, ta.ema(close, emaS)[1], barmerge.gaps_off, barmerge.lookahead_on)
float htfR  = request.security(syminfo.tickerid, htf, ta.rsi(close, rsiLen)[1], barmerge.gaps_off, barmerge.lookahead_on)

bool htfBull = htfEF > htfEM and htfEM > htfES and htfR > 45
bool htfBear = htfEF < htfEM and htfEM < htfES and htfR < 55
bool htfBullOk = htfOn ? htfBull : true
bool htfBearOk = htfOn ? htfBear : true

// ══════════════════════════════════════════════════════════════════════════════
//  SCORING — 16 факторов
// ══════════════════════════════════════════════════════════════════════════════

bool emaBull = emaFast > emaMid and emaMid > emaSlow
bool emaBear = emaFast < emaMid and emaMid < emaSlow
bool pEbull = c1 > emaFast and c1 > emaMid
bool pEbear = c1 < emaFast and c1 < emaMid
bool rsiBull = rsiVal > rsiPrev and rsiVal > 40 and rsiVal < 70
bool rsiBear = rsiVal < rsiPrev and rsiVal < 60 and rsiVal > 30
bool macdBull = macdVal > sigVal and (macdVal - sigVal) > (macdL[2] - sigL[2])
bool macdBear = macdVal < sigVal and (sigVal - macdVal) > (sigL[2] - macdL[2])
bool histBull = histVal > 0 and histVal > histPrev
bool histBear = histVal < 0 and histVal < histPrev
bool stBull = stKVal > stDVal and stKP <= stDP and stKVal < 50
bool stBear = stKVal < stDVal and stKP >= stDP and stKVal > 50
bool volBull = volSpike and c1 > o1
bool volBear = volSpike and c1 < o1
bool adxBull = adxC >= adxTh and diPC > diMC
bool adxBear = adxC >= adxTh and diMC > diPC

float maxPts = 16.0
float bS = 0.0
float sS2 = 0.0

bS  := (emaBull?1.:0.) + (pEbull?1.:0.) + (rsiBull?1.:0.) + (macdBull?1.:0.) + (histBull?1.:0.) + (stBull?1.:0.) + (volBull?1.:0.) + (adxBull?1.:0.) + (inBullOB?1.:0.) + (inBullFVG?1.:0.) + ((bullBOS or bullCHoCH)?1.:0.) + (bullSweep?1.:0.) + (inBullOTE?1.:0.) + (bullDisplace?1.:0.) + (bullDiv?1.:0.) + (bullPA?1.:0.)
sS2 := (emaBear?1.:0.) + (pEbear?1.:0.) + (rsiBear?1.:0.) + (macdBear?1.:0.) + (histBear?1.:0.) + (stBear?1.:0.) + (volBear?1.:0.) + (adxBear?1.:0.) + (inBearOB?1.:0.) + (inBearFVG?1.:0.) + ((bearBOS or bearCHoCH)?1.:0.) + (bearSweep?1.:0.) + (inBearOTE?1.:0.) + (bearDisplace?1.:0.) + (bearDiv?1.:0.) + (bearPA?1.:0.)

float bullProb = math.round(bS / maxPts * 100)
float bearProb = math.round(sS2 / maxPts * 100)

// ══════════════════════════════════════════════════════════════════════════════
//  SIGNAL GENERATION
// ══════════════════════════════════════════════════════════════════════════════

float tierAP = 12.0
float tierA  = 10.0

bool trendOk = adxC >= adxTh
bool vwLOk = vwapFilter ? c1 > vwapVal : true
bool vwSOk = vwapFilter ? c1 < vwapVal : true

bool longRaw  = bS >= tierA and bullProb > bearProb and vwLOk and trendOk and htfBullOk and inKillzone and not newsDanger
bool shortRaw = sS2 >= tierA and bearProb > bullProb and vwSOk and trendOk and htfBearOk and inKillzone and not newsDanger

var int bsSig = 999
var int lastD = 0
bsSig += 1

bool newLong  = longRaw and lastD != 1 and bsSig >= cooldownBars
bool newShort = shortRaw and lastD != -1 and bsSig >= cooldownBars

if newLong
    lastD := 1
    bsSig := 0
if newShort
    lastD := -1
    bsSig := 0

// ══════════════════════════════════════════════════════════════════════════════
//  SL / TP
// ══════════════════════════════════════════════════════════════════════════════

var float eSL = na
var float eTP = na
var float ePx = na

if newLong
    ePx := c1
    eSL := c1 - slDist
    if useFixedTP
        eTP := c1 + slDist * fixedRR
    else
        eTP := math.max(nearestRes, c1 + slDist * 2.0)

if newShort
    ePx := c1
    eSL := c1 + slDist
    if useFixedTP
        eTP := c1 - slDist * fixedRR
    else
        eTP := math.min(nearestSup, c1 - slDist * 2.0)

float actualRR = not na(ePx) and not na(eSL) and not na(eTP) and math.abs(ePx - eSL) > 0 ? math.abs(eTP - ePx) / math.abs(ePx - eSL) : 0.0

// ══════════════════════════════════════════════════════════════════════════════
//  WIN RATE
// ══════════════════════════════════════════════════════════════════════════════

var int totTr = 0
var int winTr = 0
var float trE = na
var float trSL = na
var float trTP = na
var int trD = 0
var bool trO = false

if (newLong or newShort) and not trO
    trE  := ePx
    trSL := eSL
    trTP := eTP
    trD  := newLong ? 1 : -1
    trO  := true

if trO
    bool hitTP = trD == 1 ? h1 >= trTP : l1 <= trTP
    bool hitSL = trD == 1 ? l1 <= trSL : h1 >= trSL
    if hitTP
        totTr += 1
        winTr += 1
        trO := false
    else if hitSL
        totTr += 1
        trO := false

float winRate = totTr > 0 ? math.round(winTr / totTr * 100) : 0

// ══════════════════════════════════════════════════════════════════════════════
//  PLOTS
// ══════════════════════════════════════════════════════════════════════════════

plot(showEma ? ta.ema(close, emaF) : na, "EMA F", #00bcd4, 1)
plot(showEma ? ta.ema(close, emaM) : na, "EMA M", #ff9800, 1)
plot(showEma ? ta.ema(close, emaS) : na, "EMA S", #e91e63, 2)

pBBU = plot(showBB ? bbUp : na, "BB Up", color.new(#9c27b0, 60), 1)
pBBD = plot(showBB ? bbLo : na, "BB Lo", color.new(#9c27b0, 60), 1)
fill(pBBU, pBBD, color.new(#9c27b0, 92))

plot(showVwap ? vwapVal : na, "VWAP", #ffeb3b, 2, plot.style_stepline)

string curTier = math.max(bS, sS2) >= tierAP ? "A+" : (math.max(bS, sS2) >= tierA ? "A" : "B")

if showSignals and newLong
    string txt = "LONG " + curTier + "\n" + str.tostring(bullProb) + "%" + "\nEntry: " + str.tostring(ePx, format.mintick) + "\nSL: " + str.tostring(eSL, format.mintick) + " (20p)" + "\nTP: " + str.tostring(eTP, format.mintick) + "\nR:R 1:" + str.tostring(actualRR, "#.#")
    label.new(bar_index, l1, txt, style=label.style_label_up, color=curTier == "A+" ? color.new(#00e676, 0) : color.new(#4caf50, 0), textcolor=color.black, size=size.small)

if showSignals and newShort
    string txt = "SHORT " + curTier + "\n" + str.tostring(bearProb) + "%" + "\nEntry: " + str.tostring(ePx, format.mintick) + "\nSL: " + str.tostring(eSL, format.mintick) + " (20p)" + "\nTP: " + str.tostring(eTP, format.mintick) + "\nR:R 1:" + str.tostring(actualRR, "#.#")
    label.new(bar_index, h1, txt, style=label.style_label_down, color=curTier == "A+" ? color.new(#ff1744, 0) : color.new(#e53935, 0), textcolor=color.white, size=size.small)

if showSLTP and (newLong or newShort)
    line.new(bar_index - 1, ePx, bar_index + 30, ePx, color=color.new(#ffffff, 30), style=line.style_dashed, width=1)
    line.new(bar_index - 1, eSL, bar_index + 30, eSL, color=color.new(#ff1744, 20), style=line.style_dashed, width=2)
    line.new(bar_index - 1, eTP, bar_index + 30, eTP, color=color.new(#00e676, 20), style=line.style_dashed, width=2)
    label.new(bar_index + 30, eSL, "SL 20p", style=label.style_label_left, color=color.new(#ff1744, 20), textcolor=color.white, size=size.tiny)
    label.new(bar_index + 30, eTP, "TP", style=label.style_label_left, color=color.new(#00e676, 20), textcolor=color.white, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
//  TABLE — все строки прямыми вызовами, без локальных функций
// ══════════════════════════════════════════════════════════════════════════════

var table tb = table.new(position.top_right, 3, 28, bgcolor=color.new(#1a1a1a, 0), border_color=color.new(#333333, 0), border_width=1)

if showTable
    color gC = #00e676
    color rC = #ff1744
    color nC = #555555
    color hBg = color.new(#0d0d0d, 0)
    color aBg = color.new(#141414, 0)

    table.cell(tb, 0, 0, "SCALPMASTER PRO v4", text_color=#00bcd4, text_size=size.normal, bgcolor=hBg)
    table.merge_cells(tb, 0, 0, 2, 0)
    table.cell(tb, 0, 1, "ICT / SMC / SNR Engine", text_color=#666666, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 0, 1, 2, 1)

    table.cell(tb, 0, 2, "Factor", text_color=#888888, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 2, "Bull", text_color=gC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 2, "Bear", text_color=rC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 3, "EMA Trend", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 3, emaBull ? "✓" : "—", text_color=emaBull ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 3, emaBear ? "✓" : "—", text_color=emaBear ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 4, "Price/EMA", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 4, pEbull ? "✓" : "—", text_color=pEbull ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 4, pEbear ? "✓" : "—", text_color=pEbear ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 5, "RSI (" + str.tostring(math.round(rsiVal)) + ")", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 5, rsiBull ? "✓" : "—", text_color=rsiBull ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 5, rsiBear ? "✓" : "—", text_color=rsiBear ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 6, "MACD", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 6, macdBull ? "✓" : "—", text_color=macdBull ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 6, macdBear ? "✓" : "—", text_color=macdBear ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 7, "Histogram", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 7, histBull ? "✓" : "—", text_color=histBull ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 7, histBear ? "✓" : "—", text_color=histBear ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 8, "Stochastic", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 8, stBull ? "✓" : "—", text_color=stBull ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 8, stBear ? "✓" : "—", text_color=stBear ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 9, "Volume", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 9, volBull ? "✓" : "—", text_color=volBull ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 9, volBear ? "✓" : "—", text_color=volBear ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 10, "ADX (" + str.tostring(math.round(adxC)) + ")", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 10, adxBull ? "✓" : "—", text_color=adxBull ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 10, adxBear ? "✓" : "—", text_color=adxBear ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 11, "─── ICT / SMC ───", text_color=#00bcd4, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 0, 11, 2, 11)

    table.cell(tb, 0, 12, "Order Block", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 12, inBullOB ? "✓" : "—", text_color=inBullOB ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 12, inBearOB ? "✓" : "—", text_color=inBearOB ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 13, "FVG", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 13, inBullFVG ? "✓" : "—", text_color=inBullFVG ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 13, inBearFVG ? "✓" : "—", text_color=inBearFVG ? rC : nC, text_size=size.tiny)

    bool bosB = bullBOS or bullCHoCH
    bool bosS = bearBOS or bearCHoCH
    table.cell(tb, 0, 14, "BOS/CHoCH", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 14, bosB ? "✓" : "—", text_color=bosB ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 14, bosS ? "✓" : "—", text_color=bosS ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 15, "Liq Sweep", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 15, bullSweep ? "✓" : "—", text_color=bullSweep ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 15, bearSweep ? "✓" : "—", text_color=bearSweep ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 16, "OTE Zone", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 16, inBullOTE ? "✓" : "—", text_color=inBullOTE ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 16, inBearOTE ? "✓" : "—", text_color=inBearOTE ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 17, "Displacement", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 17, bullDisplace ? "✓" : "—", text_color=bullDisplace ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 17, bearDisplace ? "✓" : "—", text_color=bearDisplace ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 18, "─── Confluence ───", text_color=#ff9800, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 0, 18, 2, 18)

    table.cell(tb, 0, 19, "Divergence", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=aBg)
    table.cell(tb, 1, 19, bullDiv ? "✓" : "—", text_color=bullDiv ? gC : nC, text_size=size.tiny, bgcolor=aBg)
    table.cell(tb, 2, 19, bearDiv ? "✓" : "—", text_color=bearDiv ? rC : nC, text_size=size.tiny, bgcolor=aBg)

    table.cell(tb, 0, 20, "Price Action", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left)
    table.cell(tb, 1, 20, bullPA ? "✓" : "—", text_color=bullPA ? gC : nC, text_size=size.tiny)
    table.cell(tb, 2, 20, bearPA ? "✓" : "—", text_color=bearPA ? rC : nC, text_size=size.tiny)

    table.cell(tb, 0, 21, "", bgcolor=#333333)
    table.cell(tb, 1, 21, "", bgcolor=#333333)
    table.cell(tb, 2, 21, "", bgcolor=#333333)

    string dir = bullProb > bearProb ? "LONG" : (bearProb > bullProb ? "SHORT" : "NEUTRAL")
    float prob = math.max(bullProb, bearProb)
    float sc = math.max(bS, sS2)
    string tier = sc >= tierAP ? "A+" : (sc >= tierA ? "A" : (sc >= 8 ? "B" : "C"))
    color pC = dir == "LONG" ? gC : (dir == "SHORT" ? rC : nC)

    string mktS = adxC >= adxTh ? (diPC > diMC ? "TREND ▲" : "TREND ▼") : "RANGE"
    color mktC = mktS == "TREND ▲" ? gC : (mktS == "TREND ▼" ? rC : #ff9800)
    string htfS = htfBull ? "▲ BULL" : (htfBear ? "▼ BEAR" : "◆ MIX")
    color htfC2 = htfBull ? gC : (htfBear ? rC : #ff9800)

    table.cell(tb, 0, 22, "Market", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=hBg)
    table.cell(tb, 1, 22, mktS, text_color=mktC, text_size=size.tiny, bgcolor=hBg)
    table.cell(tb, 2, 22, "HTF:" + htfS, text_color=htfC2, text_size=size.tiny, bgcolor=hBg)

    string kzS = inLondon ? "LONDON" : (inNY ? "NEW YORK" : "OFF")
    color kzC2 = inLondon ? #2196f3 : (inNY ? #ff9800 : nC)
    table.cell(tb, 0, 23, "Session", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=hBg)
    table.cell(tb, 1, 23, kzS, text_color=kzC2, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 1, 23, 2, 23)

    string newsS = newsActive ? "ACTIVE" : (newsDanger ? "SOON" : "CLEAR")
    color newsC = newsActive ? rC : (newsDanger ? #ff9800 : gC)
    table.cell(tb, 0, 24, "News", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=hBg)
    table.cell(tb, 1, 24, newsS, text_color=newsC, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 1, 24, 2, 24)

    table.cell(tb, 0, 25, "Signal", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=hBg)
    table.cell(tb, 1, 25, dir + " " + tier + " (" + str.tostring(prob) + "%)", text_color=pC, text_size=size.small, bgcolor=hBg)
    table.merge_cells(tb, 1, 25, 2, 25)

    string slTxt = not na(eSL) ? str.tostring(eSL, format.mintick) : "—"
    string tpTxt = not na(eTP) ? str.tostring(eTP, format.mintick) : "—"
    string rrTxt = actualRR > 0 ? "1:" + str.tostring(actualRR, "#.#") : "—"
    table.cell(tb, 0, 26, "SL/TP", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=hBg)
    table.cell(tb, 1, 26, "SL:" + slTxt + " TP:" + tpTxt + " " + rrTxt, text_color=#aaaaaa, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 1, 26, 2, 26)

    string wrT = totTr > 0 ? str.tostring(winRate) + "% (" + str.tostring(winTr) + "/" + str.tostring(totTr) + ")" : "No trades yet"
    color wrC = winRate >= 55 ? gC : (winRate >= 40 ? #ff9800 : (totTr > 0 ? rC : nC))
    table.cell(tb, 0, 27, "Win Rate", text_color=#aaaaaa, text_size=size.tiny, text_halign=text.align_left, bgcolor=hBg)
    table.cell(tb, 1, 27, wrT, text_color=wrC, text_size=size.tiny, bgcolor=hBg)
    table.merge_cells(tb, 1, 27, 2, 27)

// ══════════════════════════════════════════════════════════════════════════════
//  ALERTS + VISUAL
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(newLong, "Long Signal", "ScalpMaster v4: LONG")
alertcondition(newShort, "Short Signal", "ScalpMaster v4: SHORT")
alertcondition(newLong or newShort, "Any Signal", "ScalpMaster v4: Signal")
alertcondition(bullSweep or bearSweep, "Liquidity Sweep", "Liquidity sweep detected")
alertcondition(bullBOS or bearBOS, "BOS/CHoCH", "Break of Structure")
alertcondition(newsActive, "News Event", "High-impact news NOW")

barcolor(newLong ? #00e676 : newShort ? #ff1744 : na)
